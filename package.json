{
	"name": "quicklogger",
	"private": true,
	"version": "0.3.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:lan": "vite dev --host 0.0.0.0",
		"build": "vite build",
		"preview": "vite preview",
		"preview:lan": "vite preview --host 0.0.0.0",
		"uat": "bash scripts/uat.sh",
		"uat:docker": "docker compose -f compose.dev.yml up --build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"rotating-file-stream": "^3.2.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@vitest/coverage-v8": "^4.1.9",
		"eslint": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"fake-indexeddb": "^6.2.5",
		"idb": "^8.0.3",
		"jsdom": "^29.1.1",
		"msw": "^2.14.6",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.6.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"overrides": {
		"devalue": "^5.8.1",
		"jsdom": {
			"undici": "^7.28.0"
		},
		"@sveltejs/kit": {
			"cookie": "^0.7.0"
		}
	}
}
