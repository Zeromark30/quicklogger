{
	"name": "quicklogger",
	"private": true,
	"version": "0.1.2",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:lan": "vite dev --host 0.0.0.0",
		"build": "vite build",
		"preview": "vite preview",
		"preview:lan": "vite preview --host 0.0.0.0",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
