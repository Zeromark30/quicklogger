# quicklogger — local & self-host env vars
# Copy to .env and fill in the required ones. Commented vars show the
# default; uncomment to override.
#
# Source of truth: src/lib/server/env.ts (loadEnv()).

# --- Required ---
LUBELOGGER_URL=http://localhost:8080
LUBELOGGER_API_KEY=replace-with-your-editor-scope-key

# --- Optional (defaults shown; uncomment to override) ---
#LUBELOGGER_VOLUME_UNIT=gallons_us
#LUBELOGGER_CURRENCY=USD
#FX_PROVIDERS=frankfurter,erapi,fawazahmed
#FX_CACHE_PATH=/data/fx-cache.json
#PORT=3000
#ORIGIN=http://localhost:5173

# --- Photo OCR (v0.2.0+, optional) -------------------------------------------
# Feature activates iff at least one provider is configured. UI hides the
# camera affordances when neither is set.

# OLLAMA_VISION_URL=http://ollama:11434
# OLLAMA_VISION_MODEL=qwen2.5vl:7b
# OLLAMA_VISION_TIMEOUT_MS=60000
# OLLAMA_KEEP_ALIVE=30m

# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_VISION_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_VISION_TIMEOUT_MS=30000

# OCR_DAILY_BUDGET_USD=1.00
# OCR_RATE_LIMIT_PER_HOUR=20

# OCR_BUDGET_PATH=/data/ocr-budget.json
# OCR_AUDIT_PATH=/data/ocr-audit.jsonl
# OCR_AUDIT_KEY_PATH=/data/ocr-audit-key.txt
# OCR_AUDIT_HMAC_KEY=                       # optional override; auto-generated to OCR_AUDIT_KEY_PATH when unset

# OCR_PUMP_VOLUME_MAX=200
# OCR_PUMP_COST_MAX=500
# OCR_PUMP_PRICE_PER_UNIT_MAX=20
# OCR_ODOMETER_MAX_MI=1000000

# Max accepted OCR image size, in MiB (1–50). This is the SOLE upload-size
# gate — oversized images get a clean 413. The Docker image runs adapter-node
# with BODY_SIZE_LIMIT=0 (no transport cap) so this app-level limit is the only
# one. If you set BODY_SIZE_LIMIT yourself, keep it >= this value, or resized
# photos get truncated mid-stream and fail as "400 multipart parse failed".
# OCR_MAX_IMAGE_MB=5

# --- New slots (v0.2.2+) ----------------------------------------------------

# Ollama Cloud — same wire protocol as local ollama, Bearer-auth.
# Sign up at https://ollama.com and create a free-tier API key.
# OLLAMA_CLOUD_API_KEY=sk-...
# OLLAMA_CLOUD_URL=https://ollama.com
# OLLAMA_CLOUD_MODEL=gemma4:31b
# OLLAMA_CLOUD_TIMEOUT_MS=30000

# Any OpenAI-compatible vision endpoint — Groq, Cerebras, OpenAI direct,
# LiteLLM proxies, etc. All three of URL/KEY/MODEL must be set to enable.
# OPENAI_COMPATIBLE_URL=https://api.groq.com/openai/v1/chat/completions
# OPENAI_COMPATIBLE_API_KEY=gsk_...
# OPENAI_COMPATIBLE_MODEL=llama-3.2-90b-vision-preview
# OPENAI_COMPATIBLE_TIMEOUT_MS=30000

# Chain order — CSV of slot identifiers. When unset, defaults to the
# configured slots in order [ollama-local, openrouter, ollama-cloud,
# openai-compatible] (back-compat preserving). Unknown slot names fail
# boot with EnvError.
# OCR_PROVIDER_CHAIN=ollama-cloud,ollama-local,openrouter

# --- Logging (v0.2.3+) -------------------------------------------------------
LOG_LEVEL=info
# LOG_PRETTY=0
# LOG_FILE_PATH=/data/logs/quicklogger.log
# LOG_FILE_MAX_SIZE_MB=5
# LOG_FILE_MAX_FILES=5

# --- Dev prod-mirror compose (compose.dev.yml, v0.3.0+) ----------------------
# Layer 1 (localhost): `docker compose -f compose.dev.yml up --build` — defaults
# give http://localhost:3000 with the service worker registered (PWA testable).
# Leave ORIGIN unset for localhost; if you set it below (for phone testing) it
# shadows the localhost default.
#
# Layer 2 (on-device phone over HTTPS): a phone on a LAN IP isn't a secure
# context, so the SW needs HTTPS via your reverse proxy. Set these in your
# (gitignored) .env to attach the dev container to your Traefik network. Use a
# DEV-ONLY hostname distinct from your production deployment so the two don't
# collide.
# ORIGIN=https://quickloggerdev.example.com
# TRAEFIK_ENABLE=true
# TRAEFIK_HOST=quickloggerdev.example.com
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_CERTRESOLVER=your-resolver
# TRAEFIK_NETWORK=your-proxy-network
# TRAEFIK_NETWORK_EXTERNAL=true
# HOST_PORT=3000   # change if 3000 is already bound on this host
